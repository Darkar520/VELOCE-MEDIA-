# ============================================================
# VELOCE MEDIA STUDIO - BACKEND CONFIGURATION
# ============================================================
# Copia este archivo a .env y ajusta los valores necesarios.
# $ cp .env.example .env
# ============================================================

# Puerto del microservicio (default: 4000)
PORT=4000

# Directorio donde se guardan los archivos descargados
# (default: ./library, relativo a backend/)
# DOWNLOAD_DIR=/sdcard/Download/Veloce
